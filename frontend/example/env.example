# =============================================================================
# KMS-Connect Frontend – env.example
# Copy to .env and fill in values. Do not commit .env to git.
# Vite exposes only variables prefixed with VITE_ to the client.
# =============================================================================
#
# iPhone / LAN dev: set IP Mac Anda (ipconfig getifaddr en0). Backend must run:
#   python manage.py runserver 0.0.0.0:8000
#

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# Backend API base URL. Must match CORS_ALLOWED_ORIGINS in backend .env.
# Development (same machine): http://localhost:8000
# Physical device on Wi‑Fi: http://YOUR_LAN_IP:8000 — only if you also open the SPA at
# http://YOUR_LAN_IP:3000 (same host as API). If you use http://localhost:3000 on the Mac,
# keep the API on http://localhost:8000 or cookies (SameSite=Lax) will not be sent.
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000

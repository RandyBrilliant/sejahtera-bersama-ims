# =============================================================================
# Sejahtera Bersama IMS – frontend env template
# Copy to .env.local or .env and adjust. Do not commit secrets.
# Vite exposes only variables prefixed with VITE_ to the client.
# =============================================================================
#
# LAN / phone testing: use your machine IP for both SPA and API origins so
# cookies (SameSite=Lax) match. Backend should listen on 0.0.0.0 if needed.
#

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# Django REST API base URL (no trailing slash). Align with backend CORS settings.
# Local: http://localhost:8000
# Production: https://api.example.com
VITE_API_URL=http://localhost:8000
